# Copy to .env.local for local dev. None of these are required to run the
# app — sensible fallbacks (seed data + stub LLM + open admin) keep the
# product working without any env config. Set these to enable the full stack.

# Postgres connection string. When unset, the assessment engine and intelligence
# portal both fall back to seed data; persistence is skipped.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ranking_engine?schema=public"

# Anthropic API key for the LLM Evidence Extractor + Classifier (spec §15).
# When unset, the agents return deterministic stub proposals so the pipeline
# still runs end-to-end. SERVER-ONLY — never expose as NEXT_PUBLIC_*.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# Optional model overrides (default haiku for extraction, opus for analyst synthesis).
ANTHROPIC_EXTRACT_MODEL=
ANTHROPIC_ANALYST_MODEL=
# Effort for the Opus analyst tier in the competitive-intel monitor (low|medium|high|max).
# Defaults to "medium" — the cost/quality sweet spot for the short whyItMatters output;
# raise to "high" when the analyst voice needs more reasoning per finding.
ANTHROPIC_INTEL_EFFORT=

# Admin gate. In dev, set ADMIN_API_OPEN=1 to bypass the token check entirely.
# In prod, set ADMIN_API_TOKEN to a strong secret and rotate regularly.
ADMIN_API_OPEN=
ADMIN_API_TOKEN=

# Cron auth. The Vercel scheduler sends this as `Authorization: Bearer <CRON_SECRET>`
# so only the scheduler (and admins) can trigger the shared, LLM-spending refresh.
CRON_SECRET=

# Resend API key for transactional email (newsletter double opt-in, watchlist
# alerts). Unset = email sends are no-ops (capture still records pending rows).
RESEND_API_KEY=
# Server-only salt for the anonymous buyer-intent session hash. MUST be set in
# prod (`openssl rand -hex 32`) — unset falls back to a guessable dev salt.
INTENT_HASH_SALT=

# ── Shared-refresh cost guardrails (Phase 1) ────────────────────────────────
# The daily refresh is the ONLY thing that spends Anthropic credits, so it is
# hard-capped. These keep a flood of free users from ever becoming runaway cost.
#
# Kill switch: set to 1 to HALT all refresh LLM spend (redeploy-safe). Either
# this OR the runtime DB row (toggled via /api/admin/refresh-guards) stops it.
REFRESH_KILL_SWITCH=
# Per-run hard cap (USD). No further LLM step starts once a run reaches this.
REFRESH_CYCLE_CAP_USD=5
# Per-UTC-day hard cap (USD) across all runs.
REFRESH_DAY_CAP_USD=25
# Set to 1 to run sourcing extraction via the two-phase Anthropic Batch API
# (~50% cheaper, async: submit one cycle, collect the next). Default off = the
# proven synchronous path. Turn on only after validating the flow in preview.
SOURCING_BATCH_MODE=
