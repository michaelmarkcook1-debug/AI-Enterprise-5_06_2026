# Copy to .env.local for local dev. None of these are required to run the
# app — sensible fallbacks (seed data + stub LLM + open admin) keep the
# product working without any env config. Set these to enable the full stack.

# Postgres connection string. When unset, the assessment engine and intelligence
# portal both fall back to seed data; persistence is skipped.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ranking_engine?schema=public"

# Anthropic API key for the LLM Evidence Extractor + Classifier (spec §15).
# When unset, the agents return deterministic stub proposals so the pipeline
# still runs end-to-end.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Admin gate. In dev, set ADMIN_API_OPEN=1 to bypass the token check entirely.
# In prod, set ADMIN_API_TOKEN to a strong secret and rotate regularly.
ADMIN_API_OPEN=
ADMIN_API_TOKEN=
