# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.next.stale-*/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma
/generated/prisma/

# operator log output (large NDJSON, regenerated on each ingest)
/logs/

# linter-duplicate files (e.g. "page 2.tsx") that some IDEs create
* 2.*
* 2/
* 2

# audit / scratch scripts kept out of CI
_test-*.ts
_check.ts
_ids.ts
_classes.ts
.env*.local

# Triage audit log (append-only forensic trail; not source-controlled)
/data/triage-audit.jsonl
/data/linkage-apply-audit.jsonl
/data/*.jsonl
